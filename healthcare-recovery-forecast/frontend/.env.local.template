# Healthcare Recovery Forecast - Environment Configuration
# Copy this file to .env.local in the frontend directory

# API Backend Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Report Generation Settings
NEXT_PUBLIC_HOSPITAL_NAME=Central Medical Center
NEXT_PUBLIC_REPORT_LOGO_URL=/logo.png

# Feature Flags
NEXT_PUBLIC_ENABLE_PDF_REPORTS=true
NEXT_PUBLIC_ENABLE_BATCH_PREDICTIONS=true
NEXT_PUBLIC_ENABLE_DATA_UPLOAD=true

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Authentication (optional - JWT endpoints)
NEXT_PUBLIC_AUTH_ENABLED=false
NEXT_PUBLIC_JWT_SECRET_KEY=
